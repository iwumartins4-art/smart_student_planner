<UserView>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: app.theme_cls.backgroundColor

        MDTopAppBar:
            type: "small"
            md_bg_color: app.theme_cls.surfaceColor
            
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "arrow-left"
                    on_release: root.go_back()
                    theme_icon_color: "Custom"
                    icon_color: (0, 0, 0, 1) if app.theme_cls.theme_style == "Light" else (1, 1, 1, 1)

            MDTopAppBarTitle:
                text: "My Profile"
                theme_text_color: "Custom"
                text_color: (0, 0, 0, 1) if app.theme_cls.theme_style == "Light" else (1, 1, 1, 1)

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(24)
            spacing: dp(24)
            
            # Profile Header
            MDBoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(12)
                pos_hint: {"center_x": .5}
                
                MDIcon:
                    icon: "account-circle"
                    font_size: dp(80)
                    pos_hint: {"center_x": .5}
                    theme_icon_color: "Custom"
                    icon_color: app.theme_cls.primaryColor
                
                MDLabel:
                    text: root.full_name
                    halign: "center"
                    font_style: "Headline"
                    role: "small"
                    bold: True
                
                MDLabel:
                    text: root.email
                    halign: "center"
                    font_style: "Body"
                    role: "medium"
                    theme_text_color: "Secondary"

            # Info Cards
            MDCard:
                orientation: "vertical"
                padding: dp(16)
                size_hint_y: None
                height: self.minimum_height
                radius: dp(16)
                style: "elevated"
                md_bg_color: app.theme_cls.surfaceColor
                
                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(56)
                    
                    MDIcon:
                        icon: "school"
                        pos_hint: {"center_y": .5}
                        theme_icon_color: "Custom"
                        icon_color: app.theme_cls.primaryColor
                    
                    MDBoxLayout:
                        orientation: "vertical"
                        padding: [dp(16), 0, 0, 0]
                        
                        MDLabel:
                            text: "Major"
                            font_style: "Label"
                            role: "medium"
                            theme_text_color: "Secondary"
                        
                        MDLabel:
                            text: root.major
                            font_style: "Body"
                            role: "large"

                MDDivider:

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(56)
                    
                    MDIcon:
                        icon: "card-account-details"
                        pos_hint: {"center_y": .5}
                        theme_icon_color: "Custom"
                        icon_color: app.theme_cls.primaryColor
                    
                    MDBoxLayout:
                        orientation: "vertical"
                        padding: [dp(16), 0, 0, 0]
                        
                        MDLabel:
                            text: "Student ID"
                            font_style: "Label"
                            role: "medium"
                            theme_text_color: "Secondary"
                        
                        MDLabel:
                            text: root.student_id
                            font_style: "Body"
                            role: "large"

            Widget: # Spacer
