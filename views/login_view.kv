<LoginView>:
    MDBoxLayout:
        orientation: 'vertical'
        padding: dp(24)
        spacing: dp(24)
        md_bg_color: self.theme_cls.backgroundColor
        
        MDLabel:
            text: "Smart Student Planner"
            halign: "center"
            theme_text_color: "Primary"
            font_style: "Headline"
            role: "medium"
            size_hint_y: None
            height: dp(120)

        MDBoxLayout:
            orientation: 'vertical'
            spacing: dp(20)
            size_hint_y: None
            height: self.minimum_height
            pos_hint: {'center_y': .5}

            MDTextField:
                id: username
                mode: "outlined"
                MDTextFieldHintText:
                    text: "Username"
                MDTextFieldLeadingIcon:
                    icon: "account"

            MDTextField:
                id: password
                mode: "outlined"
                password: True
                MDTextFieldHintText:
                    text: "Password"
                MDTextFieldLeadingIcon:
                    icon: "key"

            MDBoxLayout:
                orientation: "horizontal"
                spacing: dp(16)
                size_hint_x: 1
                adaptive_height: True
                padding: [0, dp(12), 0, 0]

                MDButton:
                    style: "filled"
                    size_hint_x: .5
                    on_release: root.handle_login(username.text, password.text)
                    MDButtonText:
                        text: "LOGIN"
                        pos_hint: {"center_x": .5, "center_y": .5}

                MDButton:
                    style: "outlined"
                    size_hint_x: .5
                    on_release: root.manager.current = 'register'
                    MDButtonText:
                        text: "REGISTER"
                        pos_hint: {"center_x": .5, "center_y": .5}

        MDLabel:
            text: "Empowering your academic journey"
            halign: "center"
            theme_text_color: "Secondary"
            font_style: "Label"
            role: "medium"
