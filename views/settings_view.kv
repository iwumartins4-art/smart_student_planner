<SettingsView>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: self.theme_cls.backgroundColor

        MDTopAppBar:
            type: "small"
            md_bg_color: self.theme_cls.primaryColor
            
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "arrow-left"
                    theme_icon_color: "Custom"
                    icon_color: self.theme_cls.onPrimaryColor
                    on_release: root.go_back()
            
            MDTopAppBarTitle:
                text: "App Settings"
                theme_text_color: "Custom"
                text_color: self.theme_cls.onPrimaryColor

        ScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                padding: dp(24)
                spacing: dp(16)
                size_hint_y: None
                height: self.minimum_height

                MDLabel:
                    text: "Personalization"
                    font_style: "Title"
                    role: "large"
                    theme_text_color: "Primary"

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(64)
                    
                    MDLabel:
                        text: "Dark Mode"
                        theme_text_color: "Primary"
                    
                    MDSwitch:
                        active: True if self.theme_cls.theme_style == "Dark" else False
                        on_active: root.toggle_theme()
                        pos_hint: {"center_y": .5}

                MDDivider:

                MDLabel:
                    text: "Project Info"
                    font_style: "Title"
                    role: "large"
                    theme_text_color: "Primary"

                MDBoxLayout:
                    orientation: 'vertical'
                    spacing: dp(8)
                    size_hint_y: None
                    height: self.minimum_height

                    MDLabel:
                        text: "Version: 3.0.0 (Material 3)"
                        theme_text_color: "Secondary"
                        font_style: "Label"
                        role: "large"

                    MDLabel:
                        text: "STUDENT NAME: MARTINS CHINATU IWU"
                        theme_text_color: "Primary"
                        font_style: "Label"
                        role: "large"
                        bold: True

                    MDLabel:
                        text: "STUDENT NUMBER: 250310429"
                        theme_text_color: "Secondary"
                        font_style: "Label"
                        role: "medium"

                    MDLabel:
                        text: "Platform: KivyMD Cross-Platform Engine"
                        theme_text_color: "Secondary"
                        font_style: "Label"
                        role: "small"
