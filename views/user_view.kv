<UserView>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: app.theme_cls.backgroundColor

        MDTopAppBar:
            type: "small"
            md_bg_color: app.theme_cls.backgroundColor
            
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "arrow-left"
                    on_release: root.go_back()

            MDTopAppBarTitle:
                text: "My Profile"
                theme_text_color: "Primary"

        ScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                padding: dp(24)
                spacing: dp(24)
                adaptive_height: True
                
                # Profile Header
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_height: True
                    spacing: dp(12)
                    pos_hint: {"center_x": .5}
                    
                    MDIcon:
                        icon: "account-circle"
                        font_size: dp(80)
                        pos_hint: {"center_x": .5}
                        theme_icon_color: "Primary"
                    
                    MDLabel:
                        text: root.full_name
                        halign: "center"
                        font_style: "Headline"
                        role: "small"
                        bold: True
                        adaptive_height: True
                    
                    MDLabel:
                        text: root.email
                        halign: "center"
                        font_style: "Body"
                        role: "medium"
                        theme_text_color: "Secondary"
                        adaptive_height: True

                # Info Cards
                MDCard:
                    orientation: "vertical"
                    padding: dp(16)
                    adaptive_height: True
                    radius: dp(16)
                    style: "filled"
                    md_bg_color: app.theme_cls.surfaceContainerLowColor
                    
                    # Major Info
                    MDBoxLayout:
                        orientation: "horizontal"
                        adaptive_height: True
                        padding: [0, dp(8), 0, dp(8)]
                        
                        MDIcon:
                            icon: "school"
                            pos_hint: {"center_y": .5}
                            theme_icon_color: "Primary"
                        
                        MDBoxLayout:
                            orientation: "vertical"
                            padding: [dp(16), 0, 0, 0]
                            adaptive_height: True
                            
                            MDLabel:
                                text: "Major"
                                font_style: "Label"
                                role: "medium"
                                theme_text_color: "Secondary"
                                adaptive_height: True
                            
                            MDLabel:
                                text: root.major
                                font_style: "Body"
                                role: "large"
                                adaptive_height: True

                    # Manual Separator (Safe alternative to MDDivider)
                    Widget:
                        size_hint_y: None
                        height: dp(1)
                        canvas:
                            Color:
                                rgba: app.theme_cls.outlineVariantColor
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    # Student ID Info
                    MDBoxLayout:
                        orientation: "horizontal"
                        adaptive_height: True
                        padding: [0, dp(8), 0, dp(8)]
                        
                        MDIcon:
                            icon: "card-account-details"
                            pos_hint: {"center_y": .5}
                            theme_icon_color: "Primary"
                        
                        MDBoxLayout:
                            orientation: "vertical"
                            padding: [dp(16), 0, 0, 0]
                            adaptive_height: True
                            
                            MDLabel:
                                text: "Student ID"
                                font_style: "Label"
                                role: "medium"
                                theme_text_color: "Secondary"
                                adaptive_height: True
                            
                            MDLabel:
                                text: root.student_id
                                font_style: "Body"
                                role: "large"
                                adaptive_height: True

                Widget:
                    size_hint_y: None
                    height: dp(40)
