<TaskCard>:
    orientation: "vertical"
    size_hint_y: None
    height: dp(110)
    padding: dp(12)
    radius: dp(16)
    style: "elevated"
    md_bg_color: self.theme_cls.surfaceContainerColor
    elevation: 2
    
    MDBoxLayout:
        orientation: "horizontal"
        spacing: dp(12)
        
        # Priority Indicator
        MDBoxLayout:
            size_hint_x: None
            width: dp(6)
            radius: [dp(4), 0, 0, dp(4)]
            md_bg_color: 
                (0.8, 0.2, 0.2, 1) if root.priority == "High" else \
                (0.9, 0.6, 0.2, 1) if root.priority == "Medium" else \
                (0.2, 0.6, 0.2, 1)
            
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(2)
            pos_hint: {"center_y": .5}
            
            MDLabel:
                text: root.title
                theme_text_color: "Primary"
                font_style: "Title"
                role: "medium"
                strikethrough: root.status == "Completed"
                adaptive_height: True
                
            MDLabel:
                text: f"{root.module} • {root.due_date}"
                theme_text_color: "Secondary"
                font_style: "Label"
                role: "medium"
                adaptive_height: True

            # Status Label with Dynamic Colors
            MDBoxLayout:
                adaptive_size: True
                padding: [dp(6), dp(2), dp(6), dp(2)]
                radius: dp(4)
                md_bg_color: 
                    (0.5, 0.5, 0.5, 0.15) if root.status == "Not Started" else \
                    (1, 0.6, 0, 0.15) if root.status == "In Progress" else \
                    (0.1, 0.6, 0.1, 0.15)
                
                MDLabel:
                    text: root.status
                    font_style: "Label"
                    role: "small"
                    adaptive_size: True
                    theme_text_color: "Custom"
                    text_color: 
                        (0.6, 0.6, 0.6, 1) if root.status == "Not Started" else \
                        (1, 0.6, 0, 1) if root.status == "In Progress" else \
                        (0.2, 0.7, 0.2, 1)

        # Action Button (3-dot menu)
        MDIconButton:
            id: menu_btn
            icon: "dots-vertical"
            pos_hint: {"center_y": .5}
            on_release: root.on_menu_click(self)

<DashboardView>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: self.theme_cls.backgroundColor

        MDTopAppBar:
            type: "small"
            md_bg_color: self.theme_cls.surfaceContainerColor
            
            MDTopAppBarTitle:
                text: "Student Planner"
                theme_text_color: "Primary"

            MDTopAppBarTrailingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "cog"
                    on_release: root.manager.current = 'settings'
                MDActionTopAppBarButton:
                    icon: "account-circle"
                    on_release: root.manager.current = 'user'
                MDActionTopAppBarButton:
                    icon: "logout"
                    on_release: root.confirm_logout()

        MDBoxLayout:
            orientation: 'vertical'
            padding: [dp(16), dp(8), dp(16), dp(16)]
            spacing: dp(16)

            # Header Fix: Proper vertical alignment
            MDBoxLayout:
                orientation: 'vertical'
                adaptive_height: True
                spacing: dp(4)
                
                MDLabel:
                    text: "Dashboard"
                    font_style: "Headline"
                    role: "small"
                    theme_text_color: "Primary"
                    bold: True
                    adaptive_height: True
                
                MDLabel:
                    text: f"Hi, {root.username}!"
                    font_style: "Title"
                    role: "small"
                    theme_text_color: "Secondary"
                    adaptive_height: True

            # Search Bar
            MDTextField:
                id: search_field
                mode: "outlined"
                on_text: root.refresh_tasks(self.text)
                size_hint_y: None
                height: dp(48)
                
                MDTextFieldLeadingIcon:
                    icon: "magnify"
                
                MDTextFieldHintText:
                    text: "Search tasks..."

            # Dashboard Metrics with Descriptive Labels
            MDBoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: dp(80)
                spacing: dp(12)
                
                MDCard:
                    style: "filled"
                    md_bg_color: self.theme_cls.primaryContainerColor
                    radius: dp(16)
                    padding: dp(8)
                    MDBoxLayout:
                        orientation: 'vertical'
                        MDLabel:
                            text: "Today's Tasks"
                            font_style: "Label"
                            role: "small"
                        MDLabel:
                            text: str(root.today_count)
                            font_style: "Title"
                            role: "medium"
                            bold: True

                MDCard:
                    style: "filled"
                    md_bg_color: self.theme_cls.surfaceContainerColor
                    radius: dp(16)
                    padding: dp(8)
                    MDBoxLayout:
                        orientation: 'vertical'
                        MDLabel:
                            text: "Next Deadline"
                            font_style: "Label"
                            role: "small"
                        MDLabel:
                            text: root.deadline_text
                            font_style: "Title"
                            role: "medium"
                            bold: True
                            shorten: False
                            halign: "left"

                MDCard:
                    style: "filled"
                    md_bg_color: self.theme_cls.surfaceContainerColor
                    radius: dp(16)
                    padding: dp(8)
                    MDBoxLayout:
                        orientation: 'vertical'
                        MDLabel:
                            text: "Weekly Goal"
                            font_style: "Label"
                            role: "small"
                        MDLabel:
                            text: f"{root.completion_percent}%"
                            font_style: "Title"
                            role: "medium"
                            bold: True

            # Data-Driven List
            RecycleView:
                id: task_rv
                viewclass: 'TaskCard'
                data: root.rv_data
                RecycleBoxLayout:
                    default_size: None, dp(110)
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height
                    orientation: 'vertical'
                    spacing: dp(12)
                    padding: [0, 0, 0, dp(80)]

            MDLabel:
                id: empty_label
                text: "No tasks found"
                halign: "center"
                theme_text_color: "Secondary"
                size_hint_y: None
                height: dp(40) if not root.rv_data else 0
                opacity: 1 if not root.rv_data else 0

    MDFabButton:
        icon: "plus"
        style: "standard"
        pos_hint: {"center_x": .88, "center_y": .12}
        on_release: root.go_to_add_task()
