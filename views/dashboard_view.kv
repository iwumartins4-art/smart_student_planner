<TaskCard>:
    size_hint_y: None
    height: dp(90)
    padding: dp(8)
    spacing: dp(8)
    radius: dp(16)
    style: "elevated"
    md_bg_color: app.theme_cls.surfaceColor
    elevation: 2
    
    MDBoxLayout:
        orientation: "horizontal"
        spacing: dp(12)
        
        # Priority Indicator Bar
        MDBoxLayout:
            id: priority_bar
            size_hint_x: None
            width: dp(6)
            radius: dp(4)
            md_bg_color: app.theme_cls.secondaryColor
            
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(2)
            pos_hint: {"center_y": .5}
            
            MDLabel:
                text: root.title
                theme_text_color: "Primary"
                font_style: "Title"
                role: "medium"
                strikethrough: root.is_completed
                adaptive_height: True
                
            MDLabel:
                text: f"{root.module} • {root.due_date}"
                theme_text_color: "Secondary"
                font_style: "Label"
                role: "medium"
                adaptive_height: True

        # Interactive Controls
        MDBoxLayout:
            size_hint_x: None
            width: self.minimum_width
            spacing: dp(4)
            pos_hint: {"center_y": .5}
            
            MDIconButton:
                id: check_btn
                icon: "check-circle" if root.is_completed else "circle-outline"
                theme_icon_color: "Custom"
                icon_color: (0.2, 0.6, 0.2, 1) if root.is_completed else app.theme_cls.primaryColor
                
            MDIconButton:
                id: delete_btn
                icon: "delete-outline"
                theme_icon_color: "Error"

<DashboardView>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: app.theme_cls.backgroundColor

        MDTopAppBar:
            type: "small"
            md_bg_color: app.theme_cls.surfaceColor
            
            MDTopAppBarTitle:
                text: "Student Planner"
                theme_text_color: "Custom"
                text_color: (0, 0, 0, 1) if app.theme_cls.theme_style == "Light" else (1, 1, 1, 1)

            MDTopAppBarTrailingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "account-circle"
                    theme_icon_color: "Custom"
                    icon_color: (0, 0, 0, 1) if app.theme_cls.theme_style == "Light" else (1, 1, 1, 1)
                    on_release: root.manager.current = 'user'

                MDActionTopAppBarButton:
                    icon: "cog"
                    theme_icon_color: "Custom"
                    icon_color: (0, 0, 0, 1) if app.theme_cls.theme_style == "Light" else (1, 1, 1, 1)
                    on_release: root.manager.current = 'settings'
                
                MDActionTopAppBarButton:
                    icon: "logout"
                    theme_icon_color: "Custom"
                    icon_color: (0, 0, 0, 1) if app.theme_cls.theme_style == "Light" else (1, 1, 1, 1)
                    on_release: root.confirm_logout()

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(16)
            spacing: dp(16)

            # Dashboard Summary Card
            MDCard:
                size_hint_y: None
                height: dp(120)
                padding: dp(20)
                radius: dp(24)
                style: "filled"
                md_bg_color: app.theme_cls.primaryContainerColor
                
                MDBoxLayout:
                    orientation: "horizontal"
                    spacing: dp(10)
                    
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(4)
                        
                        MDLabel:
                            text: "Your Progress"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.onPrimaryContainerColor
                            font_style: "Title"
                            role: "small"
                            adaptive_height: True
                        
                        MDLabel:
                            text: f"{root.completed_count} / {root.total_count} Tasks"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.onPrimaryContainerColor
                            font_style: "Headline"
                            role: "medium"
                            bold: True
                            adaptive_height: True
                    
                    MDAnchorLayout:
                        anchor_x: "right"
                        MDIcon:
                            icon: "chart-donut"
                            font_size: dp(48)
                            theme_icon_color: "Custom"
                            icon_color: app.theme_cls.onPrimaryContainerColor

            MDBoxLayout:
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(24), 0, dp(24), 0]
                
                MDTextField:
                    id: search_field
                    mode: "outlined"
                    on_text: root.refresh_tasks(self.text)
                    size_hint_x: 0.8
                    pos_hint: {"center_x": .5}
                    
                    MDTextFieldHintText:
                        text: "Search tasks..."
                    
                    MDTextFieldLeadingIcon:
                        icon: "magnify"

            MDLabel:
                text: "Today's Schedule"
                font_style: "Title"
                role: "medium"
                adaptive_height: True
                padding: [dp(16), 0, 0, 0]

            ScrollView:
                bar_width: 0
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_height: True
                    spacing: dp(12)
                    
                    MDLabel:
                        id: empty_label
                        text: "No tasks found matching your search"
                        halign: "center"
                        theme_text_color: "Secondary"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True
                        padding: [0, dp(40), 0, 0]
                        opacity: 0 # Hidden by default
                    
                    MDBoxLayout:
                        id: task_list
                        orientation: 'vertical'
                        spacing: dp(12)
                        size_hint_y: None
                        height: self.minimum_height
                        padding: [0, 0, 0, dp(80)]

    MDFabButton:
        icon: "plus"
        style: "standard"
        theme_bg_color: "Custom"
        md_bg_color: app.theme_cls.primaryColor
        theme_icon_color: "Custom"
        icon_color: app.theme_cls.onPrimaryColor
        pos_hint: {"center_x": .88, "center_y": .12}
        on_release: root.go_to_add_task()
