<TaskFormView>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: self.theme_cls.backgroundColor

        MDTopAppBar:
            type: "small"
            md_bg_color: self.theme_cls.surfaceContainerColor
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "arrow-left"
                    on_release: root.go_back()
            MDTopAppBarTitle:
                id: form_title
                text: "Add Task"
                theme_text_color: "Primary"

        ScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                padding: dp(24)
                spacing: dp(24)
                adaptive_height: True

                MDTextField:
                    id: title
                    mode: "outlined"
                    theme_text_color: "Primary"
                    MDTextFieldHintText:
                        text: "Task Title *"

                MDTextField:
                    id: module
                    mode: "outlined"
                    theme_text_color: "Primary"
                    MDTextFieldHintText:
                        text: "Module / Subject"

                MDBoxLayout:
                    orientation: "horizontal"
                    spacing: dp(12)
                    adaptive_height: True
                    MDTextField:
                        id: due_date
                        mode: "outlined"
                        theme_text_color: "Primary"
                        MDTextFieldHintText:
                            text: "Due Date *"
                    MDIconButton:
                        icon: "calendar"
                        pos_hint: {"center_y": .5}
                        on_release: root.show_date_picker()

                MDTextField:
                    id: priority
                    mode: "outlined"
                    readonly: True
                    theme_text_color: "Primary"
                    on_touch_down: if self.collide_point(*args[1].pos): root.open_priority_menu()
                    MDTextFieldHintText:
                        text: "Priority"
                    MDTextFieldTrailingIcon:
                        icon: "menu-down"

                MDTextField:
                    id: status
                    mode: "outlined"
                    readonly: True
                    theme_text_color: "Primary"
                    on_touch_down: if self.collide_point(*args[1].pos): root.open_status_menu()
                    MDTextFieldHintText:
                        text: "Status"
                    MDTextFieldTrailingIcon:
                        icon: "menu-down"

                MDTextField:
                    id: notes
                    mode: "outlined"
                    multiline: True
                    theme_text_color: "Primary"
                    MDTextFieldHintText:
                        text: "Additional Notes"

                MDButton:
                    style: "filled"
                    size_hint_x: 1
                    on_release: root.handle_save()
                    MDButtonText:
                        text: "SAVE TASK"
                        pos_hint: {"center_x": .5, "center_y": .5}
